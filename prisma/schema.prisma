generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Commission {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String
  price       Int
  tags        String
  creatorId   String
  createdAt   DateTime @default(now())
  clicks      Click[]
  creator     Users    @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  orders      Order[]
}

model Order {
  id           String     @id @default(cuid())
  commissionId String
  buyerId      String
  status       String     @default("pending")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  buyer        Users      @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  commission   Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
}

model Click {
  id           String     @id @default(cuid())
  commissionId String
  userId       String
  createdAt    DateTime   @default(now())
  commission   Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  user         Users      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Users {
  id           String       @id(map: "User_pkey") @default(uuid()) @map("id")
  email        String       @unique(map: "User_email_key")
  date_created DateTime     @default(now())
  password     String?
  clicks       Click[]
  commissions  Commission[]
  orders       Order[]
  profiles     Profiles?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Profiles {
  id       String   @id @default(cuid())
  user_id  String   @unique @map("user-id")
  handle   String   @unique
  avatar   String?
  bio      String?
  verified Boolean?
  name     String?
  user     Users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
